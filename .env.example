# Single nginx gateway in front of every backend service.
# Paths are routed by prefix:
#   /api/v1/auth/*          -> auth-service
#   /api/v1/tracking/*      -> tracking-service
#   /api/v1/dashboard/*     -> dashboard-service
#   /api/v1/therapist/*     -> therapist-api (prefix stripped by nginx)
#   /api/v1/social/*        -> social-api (prefix stripped by nginx)
#   /api/v1/notification/*  -> notification-service (prefix stripped by nginx)
#   /api/v1/ai/*            -> ai-service
VITE_API_BASE_URL=http://85.211.241.204:8080

# STOMP WebSocket goes directly to social-api, bypassing nginx.
VITE_CHAT_WS_URL=ws://85.211.241.204:8086/ws
